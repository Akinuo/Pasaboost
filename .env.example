# ============================================================
# PasaBoost — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ============================================================

# ── Supabase (Frontend + Backend) ────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — SERVER ONLY. Never prefix with NEXT_PUBLIC_.
# Only needed if you use createServiceRoleClient() for admin operations.
# Get from: Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=
# Used by `npm run db:types` to regenerate lib/database.types.ts
SUPABASE_PROJECT_ID=

# ── Groq API (Backend only — used inside app/api/score-essay) ─
# Get from: https://console.groq.com/keys
GROQ_API_KEY=

# ── Cron protection (Backend only) ───────────────────────────
# Secures /api/generate-daily-prompts so only Vercel Cron (or you,
# manually) can trigger it. Vercel automatically sends this as
# `Authorization: Bearer $CRON_SECRET` on its own scheduled requests
# once this env var is set — no extra config needed on Vercel's side.
# Generate any random string, e.g.: openssl rand -hex 32
CRON_SECRET=

# ── Google OAuth (optional, for Google Sign-In) ──────────────
# Configure in: Supabase Dashboard → Authentication → Providers → Google
# These are only needed if running the Supabase CLI locally (supabase/config.toml)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ── Resend (Backend only — used inside app/api/send-weekly-emails) ─
# Powers the "Email Notifications" toggle in Profile settings: weekly
# progress summaries + writing reminders. Get an API key from
# https://resend.com/api-keys. RESEND_FROM_EMAIL must be a verified
# sender/domain in your Resend account (e.g. "PasaBoost <updates@yourdomain.com>").
# If unset, /api/send-weekly-emails returns 503 and sends nothing —
# the toggle still saves the preference either way.
RESEND_API_KEY=
RESEND_FROM_EMAIL=
