{
  "framework": "nextjs",
  "buildCommand": "next build",
  "devCommand": "next dev",
  "installCommand": "npm install",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/generate-daily-prompts",
      "schedule": "0 16 * * *"
    },
    {
      "path": "/api/send-weekly-emails",
      "schedule": "0 1 * * 1"
    },
    {
      "path": "/api/send-inactivity-reminders",
      "schedule": "0 11 * * *"
    }
  ]
}
